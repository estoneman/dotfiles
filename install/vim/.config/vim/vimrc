"""""
" Maintainer:
"       Ethan Stoneman - @estoneman
"
" Sections:
"    -> General
"    -> Options
"    -> Settings
"    -> Plugins (managed via Plug)
"    -> Colors
"    -> Maps
"""""

"""""
" => General
"""""
" enables lexical highlighting
syntax enable
" enable filetype plugins
filetype plugin on
filetype indent on
let mapleader = ","

"""""
" => Options
"""""
" my statusline (see $XDG_CONFIG_HOME/vim/autoload/statusline.vim)
set statusline=%{%statusline#RegOrNetrw()%}
" i live in tmux
set term=tmux-256color
" set character encoding
set enc=utf-8
" expand tabs, enable autoindent, and set textwidth to 80 respectively
set et sw=4 ts=4 ai tw=80
" relative line numbering
set nu rnu
" disable swapfile
set noswapfile
" disable backup
set nobackup
" don't keep modified buffers open when navigating
set hidden
" set scrolloff
set so=8
" pretty cool command line completion
set wildmenu
" mini pop-up menu of completions
set wildoptions=pum
" ignore case when searching
set ignorecase
" when searching try to be smart about letter case
set smartcase
" highlight search matches
set hlsearch
" only show next match when searching
set incsearch
" add extra column to the left of buffers
set foldcolumn=1

"""""
" => Settings
"""""
let g:netrw_banner=0
let g:netrw_liststyle=3

"""""
" => Plugins
"""""
call plug#begin()

" list desired plugins here
Plug 'rose-pine/vim'
Plug 'junegunn/fzf', { 'do': { -> fzf#install() } }
Plug 'junegunn/fzf.vim'

call plug#end()

"""""
" => Colors
"""""
colorscheme rosepine
set bg=dark
" make background of vim transparent
hi Normal guibg=NONE ctermbg=NONE

"""""
" => Maps
"""""
func! s:SearchBufVar(name, value) abort
    " find first buffer that has variable 'name' set to 'value'
    " returns window number of buffer > 0 when found, 0 when not
    " found
    for i in range(winnr(), winnr('$'))
        if getbufvar(winbufnr(i), '&' .. a:name) == a:value
            return i
        endif
    endfor

    return 0
endfunc

func! s:LargestEntry(dir) abort
    let l:entries = readdir(a:dir)
    if len(l:entries) == 0
        return 0
    endif

    let l:max = l:entries[0]
    for e in l:entries
        let l:len_e = len(e)
        if len_e > l:max
            let l:max = len_e
        endif
    endfor

    return l:max
endfunc

func! s:OpenNetrw(stay) abort
    " stay (bool): whether to stay in netrw window or not
    let l:already_open = v:false
    let l:win = s:SearchBufVar('filetype', 'netrw')
    if l:win != 0
        let l:already_open = v:true
    endif

    if !l:already_open
        let l:width = &columns / s:LargestEntry('.')
        if l:width == 0
            let l:width = (&columns / 6)
        endif
        exe l:width .. "Lexplore"
    endif

    if !a:stay
        exe g:netrw_chgwin .. "wincmd w"
    endif
endfunc

func! s:CloseNetrw() abort
    if &filetype ==# 'netrw'
        close
    else
        let l:left = winnr('h')
        if l:left != winnr()
            execute l:left .. 'close'
        endif
    endif
endfunc

" i like navigating my projects like this for now
nnoremap <silent> <leader>Ex :call <SID>OpenNetrw(v:false)<cr>
" same as above, but stay in netrw
nnoremap <silent> <leader>Ed :call <SID>OpenNetrw(v:true)<cr>
" reverse the above action
nnoremap <silent> <leader>ex :call <SID>CloseNetrw()<cr>

" beast of a map this one is
nmap <leader>w :w!<cr>
" disable highlighting (i use when i'm done searching)
nmap <silent> <leader><c-h> :noh<cr>
" quick quit all windows (after writing all modifiable buffers of course)
nmap <silent> <leader>qa :wa<cr>:qa<cr>
